{
  "name": "@varavel/ui",
  "version": "0.0.0",
  "description": "The official Svelte & Tailwind UI library for Varavel",
  "keywords": [
    "varavel",
    "svelte",
    "ui",
    "components"
  ],
  "homepage": "https://github.com/varavelio/ui#readme",
  "bugs": {
    "url": "https://github.com/varavelio/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varavelio/ui.git"
  },
  "license": "MIT",
  "author": "Varavel",
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "!dist/**/Demo.svelte",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "types": "./dist/components/index.d.ts",
  "svelte": "./dist/components/index.js",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./blocks": {
      "types": "./dist/blocks/index.d.ts",
      "svelte": "./dist/blocks/index.js",
      "default": "./dist/blocks/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "svelte": "./dist/layouts/index.js",
      "default": "./dist/layouts/index.js"
    },
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "svelte": "./dist/brand/index.js",
      "default": "./dist/brand/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "svelte": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:vite && npm run build:svelte",
    "build:vite": "vite build",
    "build:svelte": "svelte-kit sync && svelte-package",
    "format": "npm run format:dprint && npm run format:biome",
    "format:dprint": "dprint fmt --config ./dprint.json --log-level warn",
    "format:biome": "biome format --write --config-path ./biome.json --log-level warn .",
    "lint": "npm run lint:ts && npm run lint:dprint && npm run lint:biome",
    "lint:ts": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint:dprint": "dprint check --config ./dprint.json --log-level warn",
    "lint:biome": "biome check --config-path ./biome.json --log-level warn .",
    "test": "echo ''",
    "ci": "npm run build && npm run lint && npm run test"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.56.1",
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "4.2.2",
    "dprint": "0.53.2",
    "svelte": "5.55.1",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  },
  "dependencies": {
    "@internationalized/date": "3.12.0",
    "@lucide/svelte": "1.7.0",
    "@tailwindcss/typography": "0.5.19",
    "bits-ui": "2.17.2",
    "clsx": "2.1.1",
    "svelte-sonner": "1.1.0",
    "tailwind-merge": "3.5.0"
  }
}
